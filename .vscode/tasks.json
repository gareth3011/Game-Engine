{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build (KickAssembler)",
      "type": "shell",
      "command": "java",
      "args": [
        "-jar",
        "D:/Development/C64/Utilities/Kick Assembler/KickAss.jar",
        "Game Engine Entry.asm",
        "-odir",
        "."
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run VICE 64 (Game Engine Entry.prg)",
      "type": "shell",
      "command": "\"D:/Development/C64/Utilities/Vice/bin/x64sc.exe\"",
      "args": [
        "-autostart",
        "${workspaceFolder}/Game Engine Entry.prg"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run C64 Debugger",
      "type": "shell",
      "command": "\"D:/Development/C64/Utilities/C64 Debugger/C64Debugger.exe\"",
      "args": [
        "${workspaceFolder}/Game Engine Entry.prg"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
